# APP_URL: The public URL where this server is hosted (e.g., https://yourdomain.com).
# Used for self-referential links, callbacks, and API configuration.
APP_URL="https://your-domain.com"

# BITESHIP_API_KEY: Optional logistics partner key (GoSend, Grab, J&T, JNE, SiCepat real-time tracking)
# Leave blank to fallback to a highly accurate local Distance & Tariff calculator
BITESHIP_API_KEY=""

# RAJAONGKIR_API_KEY: Optional RajaOngkir key for live postage rate checks
RAJAONGKIR_API_KEY=""
